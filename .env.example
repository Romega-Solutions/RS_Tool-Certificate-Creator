# PostgreSQL connection for the email queue.
# Use a real value in .env.local. Do not commit secrets.
DATABASE_URL=postgresql://cert_admin:replace-with-password@db.example.com:5432/certificate_queue

# n8n webhook that sends certificate emails.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/certificate-email-api

# Optional n8n API key for workflows that require an outbound credential.
N8N_API_KEY=replace-with-n8n-api-key

# Internal API key advertised to automation callers via /api/automation/schema.
# Used by /api/automation/callback when n8n sends X-API-Key.
RS_TOOL_API_KEY=replace-with-internal-tool-key

# Optional shared internal API key accepted by /api/automation/callback.
API_KEY=

# Org Chart staff-directory source used by /api/org-chart/people.
ORG_CHART_BASE_URL=http://localhost:3000
ORG_CHART_API_KEY=replace-with-org-chart-api-key

# Server-side admin credentials for the temporary internal auth flow.
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_NAME=Certificate Admin
ADMIN_EMAIL=admin@example.com
SESSION_SECRET=replace-with-long-random-secret

# ATS portal handoff contract. Temporary ADMIN_* login remains active until the
# server-side /api/auth/handoff exchange endpoint is implemented and enabled.
ATS_PORTAL_URL=https://rs-tool-ats.vercel.app/internal-tools
ATS_SSO_ISSUER_URL=https://rs-tool-ats.vercel.app
ATS_SSO_AUDIENCE=certificate_creator
ATS_SSO_EXCHANGE_SECRET=replace-with-generated-handoff-secret

# Optional bearer token n8n can use when calling /api/update-status
# or /api/automation/callback.
N8N_UPDATE_TOKEN=replace-with-n8n-callback-token

# Optional values used by the local database diagnostic scripts.
DB_HOST=db.example.com
DB_PORT=5432
DB_NAME=certificate_queue
DB_USER=cert_admin
DB_PASSWORD=replace-with-password
